# Example script.yaml for First Folio and yapper
#
# This file can live in two places:
#   ~/.config/first-folio/script.yaml   (global user defaults)
#   alongside your source file           (per-project overrides)
#
# Both are read and merged. Per-project values override global values.
# CLI flags override everything.
#
# First Folio only reads this file — it never modifies or creates it.

# --- Shared metadata ---
# These override the source document if set. In most cases, leave title/author
# in the source doc (#+TITLE, #+AUTHOR) and only set date/version here.
# title: About Time
# author: Taḋg Paul
date: "2026-04-26"
version: "Draft v3"

# --- Shared rendering options ---
# Read by both First Folio and yapper. Control which elements appear in output.
render:
  stage-directions: true
  frontmatter: true
  footnotes: true
  character-table: true
  transitions: true

# --- First Folio PDF rendering ---
# These keys are under the folio: namespace and are ignored by yapper.
folio:
  font: EB Garamond
  font-size: 11pt
  margin: 25mm
  page: a4

# --- Yapper (TTS) configuration ---
# Everything below is silently ignored by First Folio.
auto-assign-voices: true
character-voices:
  KEVIN: af_alloy
  NESSA: af_heart
  CÁIT: bf_isabella
  BEN: bm_lewis
  MARIE: bf
  GDA CONLON: am_michael
  DERMOT: bm_daniel
narrator-voice: bf_alice
intro-voice: bf_alice

dialogue-speed: 1.0
stage-direction-speed: 0.9
gap-after-dialogue: 0.3
gap-after-stage-direction: 0.5
gap-after-scene: 1.0

threads: 3

speech-substitution:
  Cáit: Kawch
  Marie: Mawree
  Gda: Garda
